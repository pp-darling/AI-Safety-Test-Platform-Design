CREATE TABLE users (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    username VARCHAR(50) UNIQUE NOT NULL,
    password_hash VARCHAR(255) NOT NULL,
    email VARCHAR(100) UNIQUE NOT NULL,
    display_name VARCHAR(100),
    role VARCHAR(20) NOT NULL DEFAULT 'tester',
    is_active BOOLEAN DEFAULT TRUE,
    last_login_at TIMESTAMP,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 测试用例表
CREATE TABLE test_cases (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    case_code VARCHAR(50) UNIQUE NOT NULL,
    case_name VARCHAR(200) NOT NULL,
    category VARCHAR(50) NOT NULL,
    risk_level VARCHAR(10) NOT NULL,
    test_prompt TEXT NOT NULL,
    expected_result TEXT NOT NULL,
    evaluation_method VARCHAR(20) DEFAULT 'auto',
    metadata JSONB,
    tags JSONB,
    is_active BOOLEAN DEFAULT TRUE,
    suite_id UUID REFERENCES test_suites(id),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    version INTEGER DEFAULT 1
);

-- 测试计划表
CREATE TABLE test_plans (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    plan_code VARCHAR(50) UNIQUE NOT NULL,
    plan_name VARCHAR(200) NOT NULL,
    project_id UUID REFERENCES projects(id),
    model_config_id UUID REFERENCES model_configs(id),
    scope JSONB NOT NULL,
    execution_config JSONB NOT NULL,
    status VARCHAR(20) DEFAULT 'draft',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 测试任务表
CREATE TABLE test_tasks (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    task_code VARCHAR(50) UNIQUE NOT NULL,
    plan_id UUID REFERENCES test_plans(id),
    model_config_snapshot JSONB NOT NULL,
    test_cases_snapshot JSONB NOT NULL,
    status VARCHAR(20) DEFAULT 'queued',
    progress JSONB DEFAULT '{"total": 0, "completed": 0, "passed": 0}',
    started_at TIMESTAMP,
    finished_at TIMESTAMP
);

-- 任务结果表
CREATE TABLE task_results (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    task_id UUID REFERENCES test_tasks(id) NOT NULL,
    case_id UUID REFERENCES test_cases(id) NOT NULL,
    is_passed BOOLEAN,
    violation_detected BOOLEAN DEFAULT FALSE,
    violation_types JSONB,
    response_time_ms INTEGER,
    raw_response JSONB,
    executed_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 国标文档表
CREATE TABLE standard_documents (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    standard_code VARCHAR(50) NOT NULL,
    standard_name VARCHAR(500) NOT NULL,
    file_path VARCHAR(500),
    status VARCHAR(20) DEFAULT 'pending',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 条款表
CREATE TABLE clauses (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    standard_id UUID REFERENCES standard_documents(id) NOT NULL,
    clause_number VARCHAR(50) NOT NULL,
    clause_title VARCHAR(500),
    clause_content TEXT,
    requirements JSONB,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 审计日志表
CREATE TABLE audit_logs (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID REFERENCES users(id),
    action VARCHAR(50) NOT NULL,
    resource_type VARCHAR(50) NOT NULL,
    resource_id UUID,
    details JSONB,
    ip_address INET,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);
```

